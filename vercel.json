{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/admin",
            "destination": "/admin.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*).apk",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/vnd.android.package-archive"
                }
            ]
        }
    ]
}